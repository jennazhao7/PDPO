{
    "model_id": "EleutherAI/pythia-1b",
    "dataset_path": "lora/preprocessing/d1_rr_flipped.jsonl",
    "output_dir": "outputs/dp_lora_pythia1b_sigma1",
    "seed": 42,
    "val_fraction": 0.1,

    "dp": true,
    "noise_multiplier": 1.0,
    "max_grad_norm": 1.0,
    "accountant": "rdp",

    "num_train_epochs": 3,
    "max_steps": -1,
    "learning_rate": 2e-5,
    "warmup_ratio": 0.03,
    "lr_scheduler_type": "cosine",
    "per_device_train_batch_size": 1,
    "gradient_accumulation_steps": 16,
    "max_seq_length": 512,

    "lora_r": 16,
    "lora_alpha": 32,
    "lora_dropout": 0.05,
    "target_modules": "query_key_value,dense_4h_to_h",

    "dpo_beta": 0.1,

    "logging_steps": 10,
    "max_eval_samples": 200,
    "gen_max_new_tokens": 128
}
